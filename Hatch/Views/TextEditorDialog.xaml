<Window x:Class="Hatch.Views.TextEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="テキスト編集 - hosts"
        Width="700" Height="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Border Background="#1E1E2E" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid Grid.Row="0" Background="#1A1A22" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="テキスト編集" Foreground="#D4D4D4" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" - hosts" Foreground="#808090" FontSize="11"
                               VerticalAlignment="Center" Margin="4,1,0,0"/>
                </StackPanel>

                <Button Grid.Column="1" Content="&#x2715;" Click="CloseButton_Click"
                        Width="40" Height="28"
                        Background="Transparent" Foreground="#808080"
                        BorderThickness="0" FontSize="12" Cursor="Hand"
                        Margin="0,0,4,0"/>
            </Grid>

            <!-- Text Editor -->
            <TextBox Grid.Row="1" x:Name="EditorTextBox"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     TextWrapping="NoWrap"
                     FontFamily="Consolas"
                     FontSize="13"
                     Padding="8"
                     Background="#1E1E2E"
                     Foreground="#E0E0E0"
                     CaretBrush="#E0E0E0"
                     BorderBrush="#383840"
                     BorderThickness="0,1,0,1"
                     SelectionBrush="#0078D4"/>

            <!-- Bottom Buttons -->
            <Border Grid.Row="2" Background="#24242C" Padding="12,8">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="保存" Width="80" Height="30" Margin="0,0,8,0"
                            Click="Save_Click"
                            Style="{StaticResource ToolbarButton}"
                            Background="#0078D4" Foreground="White" BorderBrush="#0078D4"/>
                    <Button Content="キャンセル" Width="100" Height="30"
                            Click="Cancel_Click"
                            Style="{StaticResource ToolbarButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
