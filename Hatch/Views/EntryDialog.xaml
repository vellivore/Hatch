<Window x:Class="Hatch.Views.EntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エントリの編集"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1E1E2E" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" x:Name="DialogTitle" Text="エントリの追加"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#E0E0E0" Margin="0,0,0,16"
                       MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

            <!-- IP Address -->
            <TextBlock Grid.Row="1" Text="IPアドレス:" FontSize="12"
                       Foreground="#808090" Margin="0,0,0,4"/>
            <TextBox Grid.Row="2" x:Name="IpTextBox"
                     FontSize="13" Padding="6,5"
                     Margin="0,0,0,12"
                     Background="#2D2D30"
                     Foreground="#E0E0E0"
                     CaretBrush="#E0E0E0"
                     BorderBrush="#3F3F46"
                     SelectionBrush="#0078D4"/>

            <!-- Hostname -->
            <TextBlock Grid.Row="3" Text="ホスト名:" FontSize="12"
                       Foreground="#808090" Margin="0,0,0,4"/>
            <TextBox Grid.Row="4" x:Name="HostnameTextBox"
                     FontSize="13" Padding="6,5"
                     Margin="0,0,0,12"
                     Background="#2D2D30"
                     Foreground="#E0E0E0"
                     CaretBrush="#E0E0E0"
                     BorderBrush="#3F3F46"
                     SelectionBrush="#0078D4"/>

            <!-- Comment -->
            <TextBlock Grid.Row="5" Text="コメント:" FontSize="12"
                       Foreground="#808090" Margin="0,0,0,4"/>
            <TextBox Grid.Row="6" x:Name="CommentTextBox"
                     FontSize="13" Padding="6,5"
                     Margin="0,0,0,12"
                     Background="#2D2D30"
                     Foreground="#E0E0E0"
                     CaretBrush="#E0E0E0"
                     BorderBrush="#3F3F46"
                     SelectionBrush="#0078D4"/>

            <!-- Group -->
            <TextBlock Grid.Row="7" Text="グループ:" FontSize="12"
                       Foreground="#808090" Margin="0,0,0,4"/>
            <ComboBox Grid.Row="8" x:Name="GroupComboBox"
                      FontSize="13" Padding="6,5"
                      Margin="0,0,0,16"
                      IsEditable="True"
                      Background="#2D2D30"
                      Foreground="#E0E0E0"
                      BorderBrush="#3F3F46">
                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#2D2D30"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#0078D4"/>
                </ComboBox.Resources>
            </ComboBox>
        </Grid>
    </Border>
</Window>
