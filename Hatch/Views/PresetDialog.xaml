<Window x:Class="Hatch.Views.PresetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プリセット管理"
        Width="520" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#1E1E2E" CornerRadius="8" BorderBrush="#3F3F46" BorderThickness="1">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" Text="プリセット管理"
                       FontSize="15" FontWeight="SemiBold"
                       Foreground="#E0E0E0" Margin="4,0,0,12"
                       MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"/>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Preset List -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ListBox x:Name="PresetListBox"
                             Grid.Row="0"
                             Background="#2D2D30"
                             Foreground="#E0E0E0"
                             BorderBrush="#3F3F46"
                             BorderThickness="1"
                             FontSize="13"
                             SelectionChanged="PresetListBox_SelectionChanged">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Foreground" Value="#E0E0E0"/>
                                <Setter Property="Padding" Value="8,5"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd" Background="Transparent"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#32323A"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd" Property="Background" Value="#0A3D5E"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="追加" Click="AddPreset_Click"
                                Style="{StaticResource ToolbarButton}"
                                Margin="0,0,4,0" Padding="10,4"/>
                        <Button Content="削除" Click="DeletePreset_Click"
                                Style="{StaticResource ToolbarButton}"
                                Padding="10,4"/>
                    </StackPanel>
                </Grid>

                <!-- Right: Preset Detail -->
                <Grid Grid.Column="2" x:Name="DetailPanel" IsEnabled="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="プリセット名:" FontSize="12"
                               Foreground="#808090" Margin="0,0,0,4"/>
                    <TextBox Grid.Row="1" x:Name="PresetNameTextBox"
                             FontSize="13" Padding="6,5"
                             Margin="0,0,0,12"
                             Background="#2D2D30"
                             Foreground="#E0E0E0"
                             CaretBrush="#E0E0E0"
                             BorderBrush="#3F3F46"
                             SelectionBrush="#0078D4"
                             TextChanged="PresetNameTextBox_TextChanged"/>

                    <TextBlock Grid.Row="2" Text="有効にするグループ:" FontSize="12"
                               Foreground="#808090" Margin="0,0,0,4"/>

                    <TextBlock Grid.Row="3" x:Name="NoGroupsText"
                               Text="(グループがありません)"
                               FontSize="12" Foreground="#505058"
                               Margin="0,0,0,4"
                               Visibility="Collapsed"/>

                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  Background="#2D2D30"
                                  BorderBrush="#3F3F46"
                                  BorderThickness="1"
                                  Padding="4">
                        <StackPanel x:Name="GroupCheckBoxPanel"/>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Bottom Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="閉じる" Click="Close_Click"
                        Width="80" Height="30"
                        Background="#3F3F46" Foreground="#E0E0E0"
                        BorderBrush="#3F3F46"
                        Cursor="Hand" FontSize="13"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
